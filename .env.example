# ── Firebase (required for sign-in + AI) ────────────────────────────
# Enables Google sign-in, cloud sync of your progress across devices, and the
# AI coaching layer (Gemini via Firebase AI Logic — no API key in the browser).
# Create a project at https://console.firebase.google.com, enable
# Authentication → Google, Firestore, and the Firebase AI Logic API, then copy
# the web app config here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — override the Gemini model used by the AI layer (default: gemini-3-flash)
# VITE_GEMINI_MODEL=gemini-3-flash

# Optional — override the reCAPTCHA v3 site key used for Firebase App Check.
# A default public site key is baked into the app; set this only to use your own.
# The reCAPTCHA *secret* key is NOT used here — paste it into the Firebase
# console (App Check → reCAPTCHA v3 provider), never into client code.
# VITE_RECAPTCHA_SITE_KEY=
