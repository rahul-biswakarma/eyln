# Copy to .env and fill in to enable Eyln's AI coaching features
# (open-ended answer grading, explain-my-mistake, study coach, lesson tutor).
# Without a key, the app runs fully — those features fall back to rule-based behavior.
#
# Get a key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Optional — override the model (default: gemini-2.0-flash)
# VITE_GEMINI_MODEL=gemini-2.0-flash

# ── Firebase (optional) ─────────────────────────────────────────────
# Enables Google sign-in and cloud sync of your progress across devices.
# Without these, the app runs fully on localStorage (single device, no auth).
# Create a project at https://console.firebase.google.com, enable
# Authentication → Google and Firestore, then copy the web app config here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — override the reCAPTCHA v3 site key used for Firebase App Check.
# A default public site key is baked into the app; set this only to use your own.
# The reCAPTCHA *secret* key is NOT used here — paste it into the Firebase
# console (App Check → reCAPTCHA v3 provider), never into client code.
# VITE_RECAPTCHA_SITE_KEY=
